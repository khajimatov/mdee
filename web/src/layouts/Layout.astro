---
import '../styles/global.css';
import SEO from '../components/SEO.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEO title={title} description={description} canonical={canonical} />
  </head>
  <body
    class="m-0 flex min-h-screen flex-col items-center justify-center bg-(--bg) px-5 py-8 font-sans leading-normal text-(--text)"
  >
    <a
      href="#main"
      class="sr-only absolute left-2 top-2 z-50 rounded-lg bg-(--surface) px-4 py-2 text-(--text) focus:not-sr-only focus:outline-2 focus:outline-offset-2 focus:outline-(--focus)"
    >
      Skip to content
    </a>
    <main id="main" class="w-full max-w-160">
      <slot />
    </main>
  </body>
</html>
