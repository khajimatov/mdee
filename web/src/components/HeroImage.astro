---
import { Picture } from 'astro:assets';
import mdeePng from '../assets/mdee.png';
---

<section class="my-6">
  <Picture
    src={mdeePng}
    formats={['avif', 'webp', 'png']}
    widths={[640, 1280, 1920, 2560]}
    sizes="min(calc(100vw - 2.5rem), 40rem)"
    alt="mdee running in the terminal with a markdown file open"
    class="hero-shot block h-auto w-full rounded-[10px] [&_img]:rounded-[10px]"
    loading="eager"
    fetchpriority="high"
  />
</section>
