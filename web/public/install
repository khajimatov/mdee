#!/usr/bin/env bash
# Canonical installer for mdee (also served at /install on the project site).
# Usage:
#   curl -fsSL https://mdee.bkh.dev/install | sh
#   curl -fsSL https://raw.githubusercontent.com/OWNER/REPO/main/web/install | sh
# Optional:
#   VERSION=0.1.0 sh -s  (install that tag, without leading v)
#   MDEE_GITHUB_REPO=owner/repo  (override GitHub repo, default below)
set -euo pipefail

APP=mdee
# Set default to your GitHub org/repo before publishing releases.
REPO="${MDEE_GITHUB_REPO:-khajimatov/mdee}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
ORANGE='\033[38;2;255;140;0m'
NC='\033[0m'

requested_version=${VERSION:-}

os=$(uname -s | tr '[:upper:]' '[:lower:]')
if [[ "$os" == "darwin" ]]; then
  os="mac"
fi
arch=$(uname -m)

if [[ "$arch" == "aarch64" ]]; then
  arch="arm64"
fi

filename="$APP-$os-$arch.tar.gz"

case "$filename" in
*"-linux-"*)
  [[ "$arch" == "x86_64" || "$arch" == "arm64" || "$arch" == "i386" ]] || {
    echo "${RED}Unsupported Linux arch: $arch${NC}"
    exit 1
  }
  ;;
*"-mac-"*)
  [[ "$arch" == "x86_64" || "$arch" == "arm64" ]] || {
    echo "${RED}Unsupported macOS arch: $arch${NC}"
    exit 1
  }
  ;;
*)
  echo "${RED}Unsupported OS/Arch: $os/$arch${NC}"
  exit 1
  ;;
esac

INSTALL_DIR=$HOME/.${APP}/bin
mkdir -p "$INSTALL_DIR"

if [ -z "$requested_version" ]; then
  url="https://github.com/${REPO}/releases/latest/download/${filename}"
  specific_version=$(
    curl -sf "https://api.github.com/repos/${REPO}/releases/latest" |
      awk -F'"' '/"tag_name": / { gsub(/^v/, "", $4); print $4; exit }'
  ) || true
  if [[ -z "${specific_version}" ]]; then
    echo "${RED}Failed to fetch latest release for https://github.com/${REPO}${NC}"
    exit 1
  fi
else
  url="https://github.com/${REPO}/releases/download/v${requested_version}/${filename}"
  specific_version=$requested_version
fi

print_message() {
  local level=$1
  local message=$2
  local color=""

  case $level in
  info) color="${GREEN}" ;;
  warning) color="${YELLOW}" ;;
  error) color="${RED}" ;;
  esac

  echo -e "${color}${message}${NC}"
}

download_and_install() {
  print_message info "Downloading ${ORANGE}${APP} ${GREEN}version ${YELLOW}${specific_version}${GREEN} (${filename})..."
  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' EXIT
  (
    cd "$tmp"
    curl -# -fL "$url" | tar xz
    mv "$APP" "$INSTALL_DIR/"
  )
  print_message info "Installed ${ORANGE}${APP}${GREEN} to ${YELLOW}${INSTALL_DIR}/${APP}${NC}"
}

download_and_install

add_to_path() {
  local config_file=$1
  local command=$2

  if [[ -w $config_file ]]; then
    echo -e "\n# ${APP}" >>"$config_file"
    echo "$command" >>"$config_file"
    print_message info "Added ${ORANGE}${APP} ${GREEN}to \$PATH in ${YELLOW}$config_file${NC}"
  else
    print_message warning "Could not write ${config_file}. Add to PATH manually:"
    print_message info "  $command"
  fi
}

XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}

current_shell=$(basename "${SHELL:-bash}")
case $current_shell in
fish)
  config_files="$HOME/.config/fish/config.fish"
  ;;
zsh)
  config_files="$HOME/.zshrc $HOME/.zshenv $XDG_CONFIG_HOME/zsh/.zshrc $XDG_CONFIG_HOME/zsh/.zshenv"
  ;;
bash)
  config_files="$HOME/.bashrc $HOME/.bash_profile $HOME/.profile $XDG_CONFIG_HOME/bash/.bashrc $XDG_CONFIG_HOME/bash/.bash_profile"
  ;;
ash)
  config_files="$HOME/.ashrc $HOME/.profile /etc/profile"
  ;;
sh)
  config_files="$HOME/.ashrc $HOME/.profile /etc/profile"
  ;;
*)
  config_files="$HOME/.bashrc $HOME/.bash_profile $XDG_CONFIG_HOME/bash/.bashrc $XDG_CONFIG_HOME/bash/.bash_profile"
  ;;
esac

config_file=""
for file in $config_files; do
  if [[ -f $file ]]; then
    config_file=$file
    break
  fi
done

if [[ -z $config_file ]]; then
  print_message error "No shell config file found for ${current_shell}. Add to PATH:"
  print_message info "  export PATH=${INSTALL_DIR}:\$PATH"
  exit 0
fi

if [[ ":$PATH:" != *":${INSTALL_DIR}:"* ]]; then
  case $current_shell in
  fish)
    add_to_path "$config_file" "fish_add_path $INSTALL_DIR"
    fish -c "fish_add_path $INSTALL_DIR" 2>/dev/null || true
    ;;
  zsh | bash | ash | sh)
    add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
    export PATH="$INSTALL_DIR:$PATH"
    ;;
  *)
    print_message warning "Add to PATH in ${config_file} (or similar):"
    print_message info "  export PATH=$INSTALL_DIR:\$PATH"
    export PATH="$INSTALL_DIR:$PATH"
    ;;
  esac
else
  print_message info "\$PATH already includes ${YELLOW}${INSTALL_DIR}${NC}"
fi

print_message info ""
print_message info "${GREEN}Restart your terminal or run the following for this session:${NC}"
case $current_shell in
fish)
  print_message info "  source $config_file"
  ;;
zsh)
  print_message info "  source ${config_file:-~/.zshrc}"
  ;;
bash)
  print_message info "  source ${config_file:-~/.bashrc}"
  ;;
*)
  print_message info "  source ${config_file:-~/.bashrc}  (or equivalent for your shell)"
  ;;
esac

if [ -n "${GITHUB_ACTIONS-}" ] && [ "${GITHUB_ACTIONS}" == "true" ]; then
  echo "$INSTALL_DIR" >>"$GITHUB_PATH"
  print_message info "Added ${INSTALL_DIR} to \$GITHUB_PATH"
fi
